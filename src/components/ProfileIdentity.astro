---
import type { SiteContent } from '../content';

interface Props {
  profileRail: SiteContent['profileRail'];
  actions: SiteContent['actions'];
}

const { profileRail, actions } = Astro.props;
---

<aside class="profile-identity" data-profile-identity>
  <div class="profile-identity__sticky">
    <div
      class="profile-identity__monogram"
      data-profile-monogram
      aria-hidden="true"
    >
      VC
    </div>
    <div class="profile-identity__heading">
      <h1>Vittorio Cai</h1>
      <p class="profile-identity__role">{profileRail.role}</p>
      <p class="profile-identity__location">{profileRail.currentLocation}</p>
    </div>

    <nav
      class="profile-identity__links"
      aria-label={profileRail.linksHeading}
    >
      <a href="mailto:vittorio.cai@tum.de">{actions.email}</a>
      <a
        class="external"
        href="https://linkedin.com/in/vittorio-cai"
        rel="noreferrer"
      >
        LinkedIn
      </a>
      <a
        class="external"
        href="https://github.com/VittorioCai"
        rel="noreferrer"
      >
        GitHub
      </a>
      <a
        href="/Vittorio-Cai-CV-English.pdf"
        aria-label={actions.cv}
        download
      >
        CV · EN
      </a>
    </nav>

    <figure class="profile-journey" data-profile-journey>
      <figcaption>{profileRail.journeyHeading}</figcaption>
      <svg
        class="profile-journey__map"
        viewBox="0 0 320 170"
        aria-hidden="true"
      >
        <g class="profile-journey__grid">
          <path d="M0 42.5H320M0 85H320M0 127.5H320" />
          <path d="M64 0V170M128 0V170M192 0V170M256 0V170" />
        </g>
        <path
          class="profile-journey__land"
          d="M34 45 64 24l46 4 18 25-24 21-18 39-42 8-22-32Z"
        />
        <path
          class="profile-journey__land"
          d="m157 32 45-17 55 8 42 30-15 38-40 8-19 35-43-13-18-34-29-22Z"
        />
        <path
          class="profile-journey__route"
          data-journey-route
          d="M70 110C130 28 246 42 270 108C220 18 126 24 88 62"
        />
        <g class="profile-journey__stops">
          <circle cx="70" cy="110" r="6" />
          <circle cx="270" cy="108" r="6" />
          <circle cx="88" cy="62" r="6" />
        </g>
      </svg>
      <ol class="profile-journey__stops-list">
        {
          profileRail.journeyStops.map((stop, index) => (
            <li>
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <span data-journey-stop>{stop}</span>
            </li>
          ))
        }
      </ol>
    </figure>
  </div>
</aside>

<style>
  .profile-identity {
    min-width: 0;
    padding: clamp(2rem, 5vw, 4rem) var(--pad);
    background: var(--surface);
  }

  .profile-identity__sticky {
    position: sticky;
    top: clamp(2rem, 5vw, 4rem);
  }

  .profile-identity__monogram {
    display: grid;
    place-items: center;
    width: clamp(8.5rem, 15vw, 11rem);
    aspect-ratio: 1;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--accent);
    border-radius: 50%;
    color: var(--paper);
    background: var(--accent);
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 750;
    letter-spacing: -0.08em;
    line-height: 1;
    box-shadow: 0 1.25rem 2.5rem rgb(26 78 143 / 14%);
  }

  .profile-identity__heading h1 {
    margin-bottom: 0.7rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .profile-identity__role {
    margin-bottom: 0.45rem;
    color: var(--accent);
    font-weight: 650;
  }

  .profile-identity__location {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .profile-identity__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-block: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .profile-identity__links a {
    display: flex;
    align-items: center;
    min-width: 0;
    min-height: 44px;
    padding: 0.65rem 0.5rem 0.65rem 0;
    overflow-wrap: anywhere;
    font-size: 0.82rem;
    font-weight: 650;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .profile-identity__links a:nth-child(odd) {
    border-right: 1px solid var(--line);
  }

  .profile-identity__links a:nth-child(even) {
    padding-left: 0.75rem;
  }

  .profile-identity__links a:nth-child(-n + 2) {
    border-bottom: 1px solid var(--line);
  }

  .profile-journey {
    margin: 0;
  }

  .profile-journey figcaption {
    margin-bottom: 0.75rem;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .profile-journey__map {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: var(--paper);
  }

  .profile-journey__grid {
    fill: none;
    stroke: var(--line);
    stroke-width: 0.7;
  }

  .profile-journey__land {
    fill: color-mix(in srgb, var(--accent) 8%, var(--paper));
    stroke: color-mix(in srgb, var(--accent) 32%, var(--line));
    stroke-width: 0.8;
  }

  .profile-journey__route {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 480;
    stroke-dashoffset: 0;
    animation: journey-route-in 1.3s cubic-bezier(0.16, 1, 0.3, 1) 180ms both;
  }

  .profile-journey__stops circle {
    fill: var(--paper);
    stroke: var(--accent);
    stroke-width: 3;
  }

  .profile-journey__stops-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
  }

  .profile-journey__stops-list li {
    min-width: 0;
    overflow-wrap: anywhere;
    font-size: 0.75rem;
    font-weight: 650;
    line-height: 1.25;
  }

  .profile-journey__stops-list li > span:first-child {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--accent);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
  }

  @keyframes journey-route-in {
    from {
      stroke-dashoffset: 480;
    }

    to {
      stroke-dashoffset: 0;
    }
  }

  @media (max-width: 760px) {
    .profile-identity__sticky {
      position: static;
    }

    .profile-identity__monogram {
      width: clamp(7rem, 34vw, 9rem);
    }

    .profile-identity__heading h1 {
      max-width: 10ch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .profile-journey__route {
      stroke-dashoffset: 0;
      animation: none;
    }
  }
</style>
