---
import type { SiteContent } from '../content';
import JourneyMap from './JourneyMap.astro';

interface Props {
  profileRail: SiteContent['profileRail'];
  actions: SiteContent['actions'];
}

const { profileRail, actions } = Astro.props;
---

<aside class="profile-identity" data-profile-identity>
  <div class="profile-identity__sticky">
    <div
      class="profile-identity__monogram"
      data-profile-monogram
      aria-hidden="true"
    >
      VC
    </div>
    <div class="profile-identity__heading">
      <h1>Vittorio Cai</h1>
      <p class="profile-identity__role">{profileRail.role}</p>
      <p class="profile-identity__location">{profileRail.currentLocation}</p>
    </div>

    <nav
      class="profile-identity__links"
      aria-label={profileRail.linksHeading}
    >
      <a href="mailto:vittorio.cai@tum.de">{actions.email}</a>
      <a
        class="external"
        href="https://linkedin.com/in/vittorio-cai"
        rel="noreferrer"
      >
        LinkedIn
      </a>
      <a
        class="external"
        href="https://github.com/VittorioCai"
        rel="noreferrer"
      >
        GitHub
      </a>
      <a
        href="/Vittorio-Cai-CV-English.pdf"
        aria-label={actions.cv}
        download
      >
        CV · EN
      </a>
    </nav>

    <JourneyMap
      heading={profileRail.journeyHeading}
      stops={profileRail.journeyStops}
    />
  </div>
</aside>

<style>
  .profile-identity {
    min-width: 0;
    background: var(--surface);
  }

  .profile-identity__sticky {
    position: sticky;
    top: 75px;
    max-height: calc(100svh - 75px);
    padding: clamp(2rem, 5vw, 4rem) var(--pad);
    overflow-y: auto;
  }

  .profile-identity__monogram {
    display: grid;
    place-items: center;
    width: clamp(8.5rem, 15vw, 11rem);
    aspect-ratio: 1;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--accent);
    border-radius: 50%;
    color: var(--paper);
    background: var(--accent);
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 750;
    letter-spacing: -0.08em;
    line-height: 1;
    box-shadow: 0 1.25rem 2.5rem rgb(26 78 143 / 14%);
  }

  .profile-identity__heading h1 {
    margin-bottom: 0.7rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .profile-identity__role {
    margin-bottom: 0.45rem;
    color: var(--accent);
    font-weight: 650;
  }

  .profile-identity__location {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .profile-identity__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-block: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .profile-identity__links a {
    display: flex;
    align-items: center;
    min-width: 0;
    min-height: 44px;
    padding: 0.65rem 0.5rem 0.65rem 0;
    overflow-wrap: anywhere;
    font-size: 0.82rem;
    font-weight: 650;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
  }

  .profile-identity__links a:nth-child(odd) {
    border-right: 1px solid var(--line);
  }

  .profile-identity__links a:nth-child(even) {
    padding-left: 0.75rem;
  }

  .profile-identity__links a:nth-child(-n + 2) {
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 760px) {
    .profile-identity__sticky {
      position: static;
      max-height: none;
      overflow-y: visible;
    }

    .profile-identity__monogram {
      width: clamp(7rem, 34vw, 9rem);
    }

    .profile-identity__heading h1 {
      max-width: 10ch;
    }
  }

</style>
