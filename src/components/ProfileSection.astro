---
import type { SiteContent } from '../content';

interface Props {
  heading: SiteContent['sections']['profile'];
  profile: SiteContent['profile'];
  education: SiteContent['education'];
}

const { heading, profile, education } = Astro.props;

const educationLogos = {
  tum: {
    src: '/institutions/tum-logo.svg',
    width: 73,
    height: 38,
  },
  wzu: {
    src: '/institutions/wenzhou-university-logo.svg',
    width: 292,
    height: 292,
  },
} as const;
---

<section
  id="profile"
  class="profile-content-section"
  aria-labelledby="profile-heading"
>
  <header
    class="profile-content-section__header reveal"
    data-reveal-delay="0"
  >
    <h2 id="profile-heading">{heading}</h2>
  </header>
  <div class="profile-content-section__body">
    <p class="profile-copy reveal" data-reveal-delay="80">{profile}</p>
    <div class="profile-timeline">
      {
        education.map((entry, index) => {
          const logo = educationLogos[entry.institution];

          return (
            <article
              class="profile-timeline__entry reveal"
              data-reveal-delay={String(140 + index * 120)}
            >
              <p class="profile-timeline__period">{entry.period}</p>
              <span class="profile-timeline__dot" aria-hidden="true"></span>
              <div class="profile-timeline__institution">
                <span
                  class={`profile-timeline__logo profile-timeline__logo--${entry.institution}`}
                  aria-hidden="true"
                >
                  <img
                    data-education-logo
                    src={logo.src}
                    alt=""
                    width={logo.width}
                    height={logo.height}
                    loading="lazy"
                    decoding="async"
                  />
                </span>
                <div class="profile-timeline__content">
                  <h3>{entry.school}</h3>
                  <p>{entry.degree}</p>
                  <p>{entry.location}</p>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
