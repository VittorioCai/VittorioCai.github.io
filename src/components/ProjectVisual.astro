---
import type { SiteContent } from '../content';

type Props =
  | {
      projectId: 'patentpath';
      label: string;
    }
  | {
      projectId: 'english-job-agent';
      label: string;
      stages: SiteContent['visuals']['jobAgentStages'];
    };

const props = Astro.props;
---

{
  props.projectId === 'patentpath' && (
    <div class="project-visual patent-visual" role="img" aria-label={props.label}>
      <div class="browser-bar" aria-hidden="true">
        <i></i><i></i><i></i><span></span>
      </div>
      <div class="patent-workspace" aria-hidden="true">
        <div class="design-input">
          <span></span><span></span><span></span>
        </div>
        <div class="report-stack">
          <div class="report-panel">
            <strong></strong><span></span><span></span>
          </div>
          <div class="report-panel">
            <strong></strong><span></span><span></span>
          </div>
        </div>
      </div>
    </div>
  )
}

{
  props.projectId === 'english-job-agent' && (
    <div
      class="project-visual job-visual"
      data-project-visual="english-job-agent"
      role="list"
      aria-label={props.label}
    >
      <span class="pipeline-stage" role="listitem">{props.stages[0]}</span>
      <b aria-hidden="true">→</b>
      <span class="pipeline-stage" role="listitem">{props.stages[1]}</span>
      <b aria-hidden="true">→</b>
      <span class="pipeline-stage" role="listitem">{props.stages[2]}</span>
    </div>
  )
}

<style>
  .project-visual {
    width: 100%;
    color: var(--accent);
  }

  .patent-visual {
    border: 1px solid var(--ink);
    background: var(--paper);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    height: 2rem;
    padding-inline: 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  .browser-bar i {
    width: 0.45rem;
    height: 0.45rem;
    border: 1px solid var(--accent);
  }

  .browser-bar span {
    width: 42%;
    height: 0.35rem;
    margin-left: auto;
    background: var(--line);
  }

  .patent-workspace {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 1rem;
    padding: clamp(1rem, 4vw, 2rem);
  }

  .design-input,
  .report-panel {
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .design-input {
    min-height: 12rem;
    padding: 1rem;
  }

  .design-input span,
  .report-panel span,
  .report-panel strong {
    display: block;
    height: 0.45rem;
    margin-bottom: 0.75rem;
    background: var(--line);
  }

  .design-input span:nth-child(2) {
    width: 78%;
  }

  .design-input span:nth-child(3) {
    width: 58%;
  }

  .report-stack {
    display: grid;
    gap: 1rem;
  }

  .report-panel {
    min-height: 5.5rem;
    padding: 1rem;
  }

  .report-panel strong {
    width: 35%;
    background: var(--accent);
  }

  .report-panel span:last-child {
    width: 70%;
    margin-bottom: 0;
  }

  .job-visual {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
  }

  .pipeline-stage {
    display: grid;
    place-items: center;
    min-width: 0;
    min-height: 3.5rem;
    padding: 0.5rem 0.3rem;
    border: 1px solid var(--line);
    color: var(--ink);
    background: var(--surface);
    font-size: 0.72rem;
    line-height: 1.2;
    text-align: center;
    overflow-wrap: anywhere;
  }

  .pipeline-stage:last-child {
    border-color: var(--accent);
  }

  .job-visual b {
    font-weight: 400;
  }

  @media (max-width: 460px) {
    .patent-workspace {
      grid-template-columns: minmax(0, 1fr);
    }

    .design-input {
      min-height: 7rem;
    }
  }
</style>
