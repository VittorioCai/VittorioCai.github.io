---
import { getContent } from '../content';
import type { Locale } from '../content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedProject from './FeaturedProject.astro';
import Hero from './Hero.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getContent(locale);
const [featured] = copy.projects;
---

<BaseLayout
  locale={locale}
  route="home"
  title={copy.meta.title}
  description={copy.meta.description}
>
  <Hero hero={copy.hero} actions={copy.actions} locale={locale} />
  <section id="work" aria-labelledby="work-heading">
    <div class="section-heading reveal" data-reveal-delay="0">
      <h2 id="work-heading">{copy.sections.work}</h2>
    </div>
    <FeaturedProject
      locale={locale}
      project={featured}
      sections={copy.sections}
      actions={copy.actions}
      allProjectsLink
    />
  </section>
</BaseLayout>

<style>
  h2 {
    margin-bottom: 0;
  }
</style>
