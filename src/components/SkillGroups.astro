---
import type { SiteContent } from '../content';

interface Props {
  heading: SiteContent['sections']['skills'];
  skillGroups: SiteContent['skillGroups'];
  languages: SiteContent['languages'];
  languageHeading: SiteContent['sections']['languages'];
}

const { heading, skillGroups, languages, languageHeading } = Astro.props;
---

<section
  id="skills"
  class="profile-content-section"
  aria-labelledby="skills-heading"
>
  <header
    class="profile-content-section__header reveal"
    data-reveal-delay="0"
  >
    <h2 id="skills-heading">{heading}</h2>
  </header>
  <div class="profile-content-section__body profile-skills">
    {
      skillGroups.map((group, index) => (
        <section
          class="profile-skill-group reveal"
          data-reveal-delay={String(index * 120)}
        >
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))
    }
    <section
      class="profile-skill-group reveal"
      data-skill-group="languages"
      data-reveal-delay={String(skillGroups.length * 120)}
    >
      <h3>{languageHeading}</h3>
      <ul>
        {languages.map((language) => <li>{language}</li>)}
      </ul>
    </section>
  </div>
</section>
