---
import Header from '../components/Header.astro';
import { getContent } from '../content';
import type { Locale } from '../content';
import {
  getLanguageLinks,
  getLocalizedPath,
} from '../i18n/routes';
import type { RouteKey } from '../i18n/routes';
import '../styles/global.css';

interface Props {
  locale: Locale;
  route: RouteKey;
  title: string;
  description: string;
  noindex?: boolean;
}

const {
  locale,
  route,
  title,
  description,
  noindex = false,
} = Astro.props;

if (!Astro.site) {
  throw new Error('Astro.site is required to build absolute metadata URLs.');
}

const site = Astro.site;
const copy = getContent(locale);
const pagePath = noindex
  ? Astro.url.pathname
  : getLocalizedPath(locale, route);
const pageUrl = new URL(pagePath, site);
const languageLinks = noindex ? [] : getLanguageLinks(route);
const ogImageUrl = new URL('/og-card.png', site);
const htmlLanguage = locale === 'zh' ? 'zh-CN' : locale;
const currentYear = new Date().getFullYear();
const showIntro = route === 'home' && !noindex;
const showPersonData = route === 'home' && !noindex;
const personData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vittorio Cai',
  url: site.origin,
  sameAs: [
    'https://github.com/VittorioCai',
    'https://linkedin.com/in/vittorio-cai',
  ],
  jobTitle: 'M.Sc. student, Management and Digital Technology (TUM)',
};
---

<!doctype html>
<html lang={htmlLanguage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!noindex && <link rel="canonical" href={pageUrl} />}
    {
      languageLinks.map((link) => (
        <link
          rel="alternate"
          hreflang={link.locale === 'zh' ? 'zh-CN' : link.locale}
          href={new URL(link.href, site)}
        />
      ))
    }
    {
      !noindex && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={new URL(getLocalizedPath('en', route), site)}
        />
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {
      showPersonData && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(personData)}
        />
      )
    }
    <noscript>
      <style is:inline>
        .intro { display: none !important; }
        [data-intro-wait] * { animation-play-state: running !important; }
      </style>
    </noscript>
  </head>
  <body>
    {
      showIntro && (
        <div class="intro" data-intro aria-hidden="true">
          <div class="intro__name" data-intro-name>
            <span class="intro__clip">
              <span class="intro__word" data-intro-word>Vittorio</span>
            </span>
            <span class="intro__clip">
              <span class="intro__word" data-intro-word>Cai</span>
            </span>
          </div>
        </div>
      )
    }
    <div class="accent-rule" aria-hidden="true"></div>
    <div class="site-shell" data-intro-wait={showIntro ? '' : undefined}>
      <Header locale={locale} route={route} />
      <main><slot /></main>
      <script>
        import { initMotion } from '../scripts/motion';

        initMotion();
      </script>
      <footer class="site-footer">
        <p>{copy.footer}</p>
        <p>&copy; {currentYear} Vittorio Cai</p>
      </footer>
    </div>
  </body>
</html>
